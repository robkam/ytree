#!/usr/bin/env bash
set -euo pipefail

MSG_FILE="${1:?commit message file required}"
SUBJECT="$(sed -n '1{s/[[:space:]]*$//;p;}' "$MSG_FILE")"

if [[ -z "$SUBJECT" ]]; then
  echo "[commit-msg] Empty commit subject is not allowed." >&2
  exit 1
fi

# Allow git-generated merge/revert subjects.
if [[ "$SUBJECT" =~ ^Merge\  ]] || [[ "$SUBJECT" =~ ^Revert\  ]]; then
  exit 0
fi

CC_REGEX='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9][a-z0-9._/-]*\))?(!)?: .+'

if [[ ! "$SUBJECT" =~ $CC_REGEX ]]; then
  cat >&2 <<'EOF'
[commit-msg] Commit subject must follow Conventional Commits:
  <type>(<scope>): <description>

Allowed types:
  feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert

Examples:
  fix(ui): preserve panel selection after volume cycle
  docs(ai): clarify mandatory mcp initialization
EOF
  echo "[commit-msg] Got: $SUBJECT" >&2
  exit 1
fi

# Disallow workflow-label wording in commit text.
if grep -Eiq '\b(task|step)\b' "$MSG_FILE"; then
  cat >&2 <<'EOF'
[commit-msg] Commit text must not use workflow labels like 'task' or 'step'.
Use durable intent/outcome wording instead.
EOF
  exit 1
fi

# By default, disallow digits in commit text to avoid ephemeral workflow IDs.
# Add [allow-digits] in the commit body only when a maintainer-approved
# exception is explicitly required.
if ! grep -Fqi '[allow-digits]' "$MSG_FILE"; then
  if grep -Eq '[0-9]' "$MSG_FILE"; then
    cat >&2 <<'EOF'
[commit-msg] Commit text must not include digits by default.
If digits are required by an explicit maintainer-approved exception,
add [allow-digits] in the commit body.
EOF
    exit 1
  fi
fi
