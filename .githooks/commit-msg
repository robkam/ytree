#!/usr/bin/env bash
set -euo pipefail

MSG_FILE="${1:?commit message file required}"
SUBJECT="$(sed -n '1{s/[[:space:]]*$//;p;}' "$MSG_FILE")"

if [[ -z "$SUBJECT" ]]; then
  echo "[commit-msg] Empty commit subject is not allowed." >&2
  exit 1
fi

# Allow git-generated merge/revert subjects.
if [[ "$SUBJECT" =~ ^Merge\  ]] || [[ "$SUBJECT" =~ ^Revert\  ]]; then
  exit 0
fi

CC_REGEX='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9][a-z0-9._/-]*\))?(!)?: .+'

if [[ ! "$SUBJECT" =~ $CC_REGEX ]]; then
  cat >&2 <<'EOF'
[commit-msg] Commit subject must follow Conventional Commits:
  <type>(<scope>): <description>

Allowed types:
  feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert

Examples:
  fix(ui): preserve panel selection after volume cycle
  docs(ai): clarify mandatory mcp initialization
EOF
  echo "[commit-msg] Got: $SUBJECT" >&2
  exit 1
fi
